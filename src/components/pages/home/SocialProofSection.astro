---
import ProfileImage from "@/assets/user-image.jpg";
import MessagesList from "@/components/shared/MessagesList.astro";
import type { Message } from "@/types/message";
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const stats = t("home.social.stats");

const messages = t("home.social.messages") as unknown as Message[];
---

<section class="relative overflow-hidden container mx-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2
      class="text-3xl font-bold text-center text-slate-900 tracking-tight sm:text-4xl mb-20"
    >
      {t("home.social.title")}
    </h2>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Left Column: Stats -->
      <div class="space-y-12">
        {
          stats.map((stat) => (
            <div>
              <div
                class={`${stat.sizeClass} font-bold text-blue-600 tracking-tight mb-2`}
              >
                {stat.value}
              </div>
              <div class="text-xl text-slate-600">{stat.label}</div>
            </div>
          ))
        }
      </div>

      <!-- Right Column: UI Mockup -->
      <div
        class="relative w-full max-w-lg md:max-w-xl mx-auto lg:max-w-none pt-8 pl-8 sm:pt-12 sm:pl-12"
      >
        <!-- Background Blue Shape -->
        <div class="gradient-blue-white"></div>

        <!-- White Interface Card -->
        <MessagesList
          messages={messages}
          className="relative bg-white rounded-xl shadow-lg overflow-hidden"
        />
      </div>
    </div>

    <!-- Bottom Testimonial -->
    <div class="relative mt-32 max-w-3xl mx-auto pl-4 border-l-0 sm:border-l-0">
      <div class="flex items-start sm:items-center justify-center gap-6">
        <div
          class="w-12 h-12 rounded-full bg-slate-900 shrink-0 flex items-center justify-center text-white text-xl overflow-hidden shadow-sm"
        >
          <Image
            src={ProfileImage}
            alt={t("home.social.testimonial.avatarAlt")}
            class="w-full h-full object-cover"
          />
        </div>
        <div>
          <p
            class="text-xl sm:text-2xl text-slate-600 font-medium leading-relaxed mb-3"
          >
            {t("home.social.testimonial.quote")}
          </p>
          <div class="font-bold text-slate-900 text-lg">
            {t("home.social.testimonial.author")}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
