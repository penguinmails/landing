---
import FeatureGrid from "@/components/shared/FeatureGrid.astro";
import {
  MessageSquare,
  Mail,
  Flame,
  Download,
  Cpu,
} from "@lucide/astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featureTexts = t("home.reach.features");
const featureIcons = [
  { icon: MessageSquare, iconClass: "w-8 h-8 text-primary" },
  { icon: Mail, iconClass: "w-8 h-8 text-primary" },
  { icon: Flame, iconClass: "w-8 h-8 text-primary" },
  { icon: Download, iconClass: "w-8 h-8 text-primary" },
  { icon: Cpu, iconClass: "w-8 h-8 text-primary" },
  { icon: Cpu, iconClass: "w-8 h-8 text-primary" },
];
const features = featureTexts.map((f, i) => ({ ...f, ...featureIcons[i] }));
---

<section class="relative overflow-hidden py-20 lg:py-24">
  <div class="w-11/12 mx-auto px-4 sm:px-6 lg:px-8 container">
    <FeatureGrid
      title={t("home.reach.title")}
      description={t("home.reach.description")}
      items={features}
      theme="light"
    />
  </div>
</section>
