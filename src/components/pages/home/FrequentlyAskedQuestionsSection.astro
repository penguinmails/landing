---
import ArticleCard from "@/components/shared/ArticleCard.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const faqs = t("home.faq.items");
---

<section class="py-20 md:py-24" id="faq">
  <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2
      class="text-center text-4xl font-semibold tracking-tight text-zinc-900 md:text-5xl"
    >
      {t("home.faq.title")}
    </h2>

    <div class="mt-10 space-y-5 md:mt-12">
      {
        faqs.map((item) => (
          <ArticleCard title={item.question} description={item.answer} />
        ))
      }
    </div>
  </div>
</section>
