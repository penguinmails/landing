---
import { TriangleAlert, TrendingDown, Octagon, Megaphone } from "@lucide/astro";

const problems = [
  {
    title: "Your emails land in spam.",
    description:
      "No matter how good your copy is, if it's in the junk folder, it's invisible.",
    icon: TriangleAlert,
    iconClass: "w-8 h-8 text-blue-500",
  },
  {
    title: "You rely on hacks instead of infrastructure.",
    description: "Temporary fixes don't build sustainable sales channels.",
    icon: Octagon,
    iconClass: "w-8 h-8 text-white",
  },
  {
    title: "Your domain reputation declines.",
    description:
      "Aggressive sending on a cold domain is a one-way ticket to blacklists.",
    icon: TrendingDown,
    iconClass: "w-8 h-8 text-purple-500",
  },
  {
    title: "You send campaigns — but get no replies.",
    description:
      'The "silence of the inbox" is usually a technical failure, not a product one.',
    icon: Megaphone,
    iconClass: "w-8 h-8 text-green-400",
  },
];
---

<section class="py-12 pb-24 bg-white relative overflow-hidden">
  <div class="w-11/12 mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-stone-900 rounded-3xl px-5 sm:px-12 py-16 sm:py-24 mx-auto">
      <div class="text-center mb-16 sm:mb-20 max-w-2xl mx-auto">
        <h2
          class="text-3xl font-bold text-white tracking-tight sm:text-5xl leading-tight mb-6"
        >
          Why Cold Email<br class="hidden sm:block" /> Software Fails You
        </h2>
        <p class="text-lg sm:text-xl text-gray-400 leading-relaxed">
          Most tools help you send more emails. They don't<br
            class="hidden sm:block"
          /> help you deliver better emails.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6">
        {
          problems.map((problem) => (
            <div class="bg-stone-800 rounded-2xl p-6 sm:p-8 border border-stone-700 flex flex-col gap-6 sm:gap-8 transition-all hover:bg-stone-700">
              <div>
                <problem.icon class={problem.iconClass} />
              </div>
              <div>
                <h3 class="text-white font-medium text-xl sm:text-2xl leading-snug mb-3 sm:mb-4 tracking-tight">
                  {problem.title}
                </h3>
                <p class="text-gray-400 text-sm sm:text-base leading-relaxed">
                  {problem.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-16 sm:mt-24 text-center">
        <p
          class="text-green-600 text-xl sm:text-2xl font-medium tracking-tight"
        >
          Cold email isn't broken. Inbox placement is.
        </p>
      </div>
    </div>
  </div>
</section>
