---
import { TriangleAlert, TrendingDown, Octagon, Megaphone } from "@lucide/astro";
import FeatureGrid from "@/components/shared/FeatureGrid.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const problemTexts = t("home.fails.problems");
const icons = [
  { icon: TriangleAlert, iconClass: "w-8 h-8 text-blue-500" },
  { icon: Octagon, iconClass: "w-8 h-8 text-white" },
  { icon: TrendingDown, iconClass: "w-8 h-8 text-purple-500" },
  { icon: Megaphone, iconClass: "w-8 h-8 text-green-400" },
];
const problems = problemTexts.map((p, i) => ({ ...p, ...icons[i] }));
---

<section class="relative overflow-hidden">
  <div class="w-11/12 mx-auto px-4 sm:px-6 lg:px-8 container">
    <FeatureGrid
      title={t("home.fails.title")}
      description={t("home.fails.description")}
      items={problems}
      theme="dark"
    >
      <div class="mt-16 sm:mt-24 text-center">
        <p
          class="text-green-600 text-xl sm:text-2xl font-medium tracking-tight"
        >
          {t("home.fails.footer")}
        </p>
      </div>
    </FeatureGrid>
  </div>
</section>
