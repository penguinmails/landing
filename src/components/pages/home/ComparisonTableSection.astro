---
import { CheckCircle2, XCircle } from "@lucide/astro";
import Tabs from "@/components/ui/Tabs.astro";
import TabsList from "@/components/ui/TabsList.astro";
import TabsTrigger from "@/components/ui/TabsTrigger.astro";
import TabsContent from "@/components/ui/TabsContent.astro";

type Status = "yes" | "no";
type StatusCell = { status: Status; text?: string };
type Cell = string | StatusCell;
type ComparisonRow = { feature: string; penguin: Cell; competitor: Cell };
type ComparisonTable = { title: string; value: string; rows: ComparisonRow[] };
type CompetitorConfig = {
  title: string;
  value: string;
  startingPrice: string;
  sendingMonthlyPlan1: Cell;
  activeContactsPlan1: Cell;
  warmups: Cell;
  privateInfra: string;
  support: Cell;
  hasPrivateSlackCommunity: boolean;
  emailAccountsAllowed?: Cell;
};

const yes: StatusCell = { status: "yes" };
const no: StatusCell = { status: "no" };
const yesText = (text: string): StatusCell => ({ status: "yes", text });
const noText = (text: string): StatusCell => ({ status: "no", text });

const penguinCopy = {
  privateInfrastructure:
    "Each user gets a separate VPS with dedicated IPs (no shared pools). Completely private infrastructure.",
};

const buildComparisonRows = (config: CompetitorConfig): ComparisonRow[] => {
  const rows: ComparisonRow[] = [
    { feature: "Starting Price", penguin: "$35/month", competitor: config.startingPrice },
    {
      feature: "Sending Emails Monthly (Plan 1)",
      penguin: "Unlimited",
      competitor: config.sendingMonthlyPlan1,
    },
    {
      feature: "Active Contacts (Prospects In Plan 1)",
      penguin: "3000",
      competitor: config.activeContactsPlan1,
    },
  ];

  if (config.emailAccountsAllowed) {
    rows.push({
      feature: "Number of Email Accounts Allowed",
      penguin: "Unlimited Email Accounts",
      competitor: config.emailAccountsAllowed,
    });
  }

  rows.push(
    {
      feature: "Number of Email Warmups",
      penguin: "Unlimited Email Warmups",
      competitor: config.warmups,
    },
    {
      feature: "Private Cold-Email Infrastructure",
      penguin: yesText(penguinCopy.privateInfrastructure),
      competitor: noText(config.privateInfra),
    },
    { feature: "Real-time Analytics", penguin: yes, competitor: yes },
    {
      feature: "Support",
      penguin: "Priority Support",
      competitor: config.support,
    },
    {
      feature: "Private Slack Community",
      penguin: yes,
      competitor: config.hasPrivateSlackCommunity ? yes : no,
    }
  );

  return rows;
};

const competitorConfigs: CompetitorConfig[] = [
  {
    title: "SmartReach",
    value: "smartreach",
    startingPrice: "$29/month",
    sendingMonthlyPlan1: "Unlimited",
    activeContactsPlan1: "1000",
    warmups: "10 Email Warmups",
    privateInfra: "No private infrastructure or dedicated IPs.",
    support: "General Support Within 24 hours",
    hasPrivateSlackCommunity: false,
  },
  {
    title: "Salesforge",
    value: "salesforge",
    startingPrice: "$48/month",
    sendingMonthlyPlan1: "5000",
    activeContactsPlan1: "1000",
    warmups: "Unlimited Email Warmups",
    privateInfra:
      "Uses Mailforge (shared IPs) by default. Dedicated IPs available only if you add Infraforge.",
    support: "Live Chat Support",
    hasPrivateSlackCommunity: true,
  },
  {
    title: "SmartLead",
    value: "smartlead",
    startingPrice: "$39/month",
    sendingMonthlyPlan1: "6000",
    activeContactsPlan1: "2000",
    warmups: "Unlimited Email Warmups",
    privateInfra:
      "Uses shared IPs and servers by default. You can add SmartServers ($39/mo) to get dedicated IPs and private infrastructure.",
    support: "General Support Within 24 hours",
    hasPrivateSlackCommunity: false,
  },
  {
    title: "Instantly",
    value: "instantly",
    startingPrice: "$37/month",
    sendingMonthlyPlan1: "5000",
    activeContactsPlan1: "1000",
    warmups: "Unlimited Email Warmups",
    privateInfra:
      "Uses a shared IP pool by default. Dedicated/private servers only on higher-tier/Lightspeed plans.",
    support: "General support tickets",
    hasPrivateSlackCommunity: true,
  },
  {
    title: "ReachInbox",
    value: "reachinbox",
    startingPrice: "$39/month",
    sendingMonthlyPlan1: "25000",
    activeContactsPlan1: "5000",
    warmups: "Unlimited Email Warmups",
    privateInfra: "No private infrastructure or dedicated IPs.",
    support: "General Support",
    hasPrivateSlackCommunity: false,
  },
  {
    title: "Emailchaser",
    value: "emailchaser",
    startingPrice: "$37/month",
    sendingMonthlyPlan1: "Unlimited",
    activeContactsPlan1: "Unlimited",
    emailAccountsAllowed: "Just 3 Email Accounts",
    warmups: noText("No Email Warmups"),
    privateInfra: "No private infrastructure or dedicated IPs.",
    support: "General Support",
    hasPrivateSlackCommunity: true,
  },
  {
    title: "Woodpecker",
    value: "woodpecker",
    startingPrice: "$29/month",
    sendingMonthlyPlan1: "6000",
    activeContactsPlan1: "500",
    warmups: "2 Email Warmups",
    privateInfra:
      "No private infra or dedicated IPs by default, but you can get private infra powered by Infraforge for an additional $59/month",
    support: "General Support",
    hasPrivateSlackCommunity: true,
  },
  {
    title: "Saleshandy",
    value: "saleshandy",
    startingPrice: "$36/month",
    sendingMonthlyPlan1: "6000",
    activeContactsPlan1: "2000",
    warmups: "Unlimited Email Warmups",
    privateInfra:
      "No private infrastructure or dedicated IPs by default, but you can get private infra powered by InfraMail for an additional $100-$300/month.",
    support: "General Support Within 24 hours",
    hasPrivateSlackCommunity: false,
  },
];

const comparisonTables: ComparisonTable[] = competitorConfigs.map((config) => ({
  title: config.title,
  value: config.value,
  rows: buildComparisonRows(config),
}));

const dotClass = (status: Status) =>
  status === "yes" ? "bg-emerald-500" : "bg-rose-500";
const iconClass = (status: Status) =>
  status === "yes"
    ? "text-emerald-500 fill-emerald-500 stroke-white"
    : "text-rose-500 fill-rose-500 stroke-white";
---

<section class="py-24 bg-white/50" id="comparison">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-10/12">
    <div class="text-center mb-10">
      <h2
        class="text-4xl md:text-5xl font-bold mb-4 tracking-tight text-slate-900"
      >
        Built for Deliverability. Not Volume.
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-lg">
        Most tools optimize sending. We optimize delivery.
      </p>
    </div>

    <Tabs defaultValue="smartreach">
      <div class="w-full overflow-x-auto pb-4 mb-4 scrollbar-hide ">
        <TabsList className="flex h-12 w-fit items-center justify-center rounded-full bg-slate-100/80 p-1 text-slate-500  mx-auto shadow-inner border border-slate-200/50">
          {comparisonTables.map((tab) => (
            <TabsTrigger 
              value={tab.value}
              className="rounded-full px-5 py-2 text-sm font-semibold transition-all data-[state=active]:bg-white data-[state=active]:text-primary data-[state=active]:shadow-md hover:text-slate-800"
            >
              {tab.title}
            </TabsTrigger>
          ))}
        </TabsList>
      </div>

      <div class="w-full mt-6">
        {comparisonTables.map((table) => (
          <TabsContent value={table.value} className="m-0 focus-visible:ring-0">
            <div
              class="bg-white rounded-2xl shadow-xl shadow-slate-200/40 border border-gray-100 overflow-hidden"
            >
              <!-- Table Header -->
              <div class="grid grid-cols-3 p-6 border-b border-gray-100 bg-slate-50/50 text-center">
                <div class="font-bold text-slate-800 text-lg text-left">Features</div>
                <div class="font-bold text-primary text-lg">PenguinMails</div>
                <div class="font-bold text-slate-800 text-lg">{table.title}</div>
              </div>

              <!-- Table Body -->
              <div class="divide-y divide-gray-100">
                {
                  table.rows.map((row) => (
                    <div class="grid grid-cols-3 p-6 items-center hover:bg-slate-50 transition-colors">
                      {/* Feature */}
                      <div class="text-slate-600 font-medium text-lg">
                        {row.feature}
                      </div>

                      {/* PenguinMails */}
                      <div class="flex items-center gap-2 text-primary font-semibold text-lg justify-center">
                        {typeof row.penguin === "string" ? (
                          row.penguin
                        ) : "text" in row.penguin && row.penguin.text ? (
                          <>
                            {row.penguin.status === "yes" ? (
                              <CheckCircle2 class={`w-4 h-4 ${iconClass(row.penguin.status)}`} />
                            ) : (
                              <XCircle class={`w-4 h-4 ${iconClass(row.penguin.status)}`} />
                            )}
                            <span>{row.penguin.text}</span>
                          </>
                        ) : (
                          <span class={`h-2.5 w-2.5 rounded-full ${dotClass(row.penguin.status)}`} />
                        )}
                      </div>

                      {/* Competitor */}
                      <div class="flex items-center gap-2 text-gray-400 font-medium text-lg justify-center ">
                        {typeof row.competitor === "string" ? (
                          row.competitor
                        ) : "text" in row.competitor && row.competitor.text ? (
                          <>
                            {row.competitor.status === "yes" ? (
                              <CheckCircle2
                                class={`w-4 h-4 ${iconClass(row.competitor.status)}`}
                              />
                            ) : (
                              <XCircle class={`w-4 h-4 ${iconClass(row.competitor.status)}`} />
                            )}
                            <span>{row.competitor.text}</span>
                          </>
                        ) : (
                          <span
                            class={`h-2.5 w-2.5 rounded-full ${dotClass(row.competitor.status)}`}
                          />
                        )}
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </TabsContent>
        ))}
      </div>
    </Tabs>
  </div>
</section>

