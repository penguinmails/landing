---
import Button from "@/components/ui/Button.astro";
import { buildSignupUrl } from "@/lib/cta";
import {
  Check,
  Clock,
  Flame,
  Mail,
  MessageSquare,
  Shield,
  Target,
  TrendingUp,
  X,
  Zap,
} from "@lucide/astro";

const { t } = Astro.props;

const highlights = t("features.warmup.highlights");
const explainerSignals = t("features.warmup.explainer.signals");
const steps = t("features.warmup.steps.items");
const reasons = t("features.warmup.why.items");
const comparisonHeaders = t("features.warmup.comparison.headers");
const comparisonRows = t("features.warmup.comparison.rows");
const myths = t("features.warmup.myths.items");
const bottomHighlights = t("features.warmup.bottomCta.highlights");

const highlightIcons = [Flame, Clock, Zap, Shield];
const stepIcons = [Mail, MessageSquare, TrendingUp];
const reasonIcons = [X, Shield, TrendingUp, Clock];
---

<div class="space-y-24 py-12">
  <section>
    <div class="mx-auto max-w-6xl px-4">
      <div class="rounded-[2rem] border border-primary/10 bg-linear-to-br from-primary/5 via-white to-sky-50 p-8 shadow-sm md:p-12">
        <div class="mx-auto max-w-4xl text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary">
            <Flame class="h-4 w-4" />
            {t("features.warmup.tabTitle")}
          </div>

          <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-5xl lg:text-6xl">
            {t("features.warmup.heading")}
          </h1>

          <p class="mt-4 text-2xl font-semibold text-primary md:text-3xl">
            {t("features.warmup.subheading")}
          </p>

          <p class="mx-auto mt-6 max-w-3xl text-lg text-slate-600 md:text-xl">
            {t("features.warmup.tagline")}
          </p>

          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <Button
              variant="primary"
              size="lg"
              href={buildSignupUrl({ context: "features_warmups" })}
            >
              {t("cta.buttonTrial")}
            </Button>
          </div>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {
            highlights.map((highlight: string, index: number) => {
              const Icon = highlightIcons[index] || Flame;

              return (
                <div class="rounded-3xl border border-white/70 bg-white/80 p-5 text-left shadow-sm backdrop-blur">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
                    <Icon class="h-6 w-6 text-primary" />
                  </div>
                  <p class="mt-4 text-base font-semibold leading-relaxed text-slate-900">
                    {highlight}
                  </p>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto grid max-w-6xl gap-10 px-4 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div>
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
          {t("features.warmup.explainer.title")}
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-600">
          {t("features.warmup.explainer.description")}
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">
          {t("features.warmup.explainer.description2")}
        </p>
      </div>

      <div class="rounded-[2rem] bg-slate-900 p-8 text-white shadow-xl">
        <p class="text-2xl font-semibold leading-tight">
          {t("features.warmup.explainer.calloutTitle")}
        </p>
        <p class="mt-4 text-base leading-relaxed text-slate-300">
          {t("features.warmup.explainer.calloutDescription")}
        </p>

        <div class="mt-8 space-y-4">
          {
            explainerSignals.map((signal: string) => (
              <div class="flex items-start gap-3 rounded-2xl bg-white/5 px-4 py-4">
                <Check class="mt-0.5 h-5 w-5 shrink-0 text-primary" />
                <span class="text-sm font-medium leading-relaxed text-slate-100">
                  {signal}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] bg-slate-50 py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
          {t("features.warmup.steps.title")}
        </h2>
        <p class="mt-4 text-lg text-slate-600 md:text-xl">
          {t("features.warmup.steps.intro")}
        </p>
      </div>

      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {
          steps.map((step: { title: string; description: string }, index: number) => {
            const Icon = stepIcons[index] || Flame;

            return (
              <div class="relative rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
                <div class="absolute -top-4 left-8 flex h-10 w-10 items-center justify-center rounded-full bg-primary text-lg font-bold text-white">
                  {index + 1}
                </div>
                <div class="pt-5">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10">
                    <Icon class="h-6 w-6 text-primary" />
                  </div>
                  <h3 class="mt-5 text-xl font-semibold text-slate-900">
                    {step.title}
                  </h3>
                  <p class="mt-3 text-base leading-relaxed text-slate-600">
                    {step.description}
                  </p>
                </div>
              </div>
            );
          })
        }
      </div>

      <p class="mx-auto mt-10 max-w-3xl text-center text-lg text-slate-600">
        {t("features.warmup.steps.conclusion")}
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-4">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
          {t("features.warmup.why.title")}
        </h2>
        <p class="mt-4 text-lg text-slate-600 md:text-xl">
          {t("features.warmup.why.subtitle")}
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {
          reasons.map(
            (
              reason: { title: string; description: string },
              index: number,
            ) => {
              const Icon = reasonIcons[index] || Target;

              return (
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-900 text-white">
                    <Icon class="h-6 w-6" />
                  </div>
                  <h3 class="mt-5 text-xl font-semibold text-slate-900">
                    {reason.title}
                  </h3>
                  <p class="mt-3 text-base leading-relaxed text-slate-600">
                    {reason.description}
                  </p>
                </div>
              );
            },
          )
        }
      </div>

      <div class="mt-10 rounded-[2rem] border border-primary/20 bg-primary/5 px-6 py-8 text-center">
        <p class="text-2xl font-semibold text-slate-900">
          {t("features.warmup.why.footerTitle")}
        </p>
        <p class="mx-auto mt-3 max-w-3xl text-lg leading-relaxed text-slate-600">
          {t("features.warmup.why.footerDescription")}
        </p>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-4">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
          {t("features.warmup.comparison.title")}
        </h2>
        <p class="mt-4 text-lg text-slate-600 md:text-xl">
          {t("features.warmup.comparison.subtitle")}
        </p>
      </div>

      <div class="mt-12 grid gap-8 lg:grid-cols-[minmax(0,1.35fr)_minmax(320px,0.65fr)] lg:items-start">
        <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-xl">
          <table class="w-full border-collapse">
            <thead class="border-b border-slate-200 bg-slate-50 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">
              <tr>
                {
                  comparisonHeaders.map((header: string, index: number) => (
                    <th
                      scope="col"
                      class:list={["px-6 py-5", index === 0 ? "text-left" : "text-center"]}
                    >
                      {header}
                    </th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                comparisonRows.map(
                  (row: { feature: string; penguin: string; others: string }) => (
                    <tr class="border-b border-slate-100 last:border-b-0">
                      <th scope="row" class="px-6 py-5 text-left font-semibold text-slate-900">{row.feature}</th>
                      <td class="px-6 py-5 text-center font-semibold text-primary">{row.penguin}</td>
                      <td class="px-6 py-5 text-center text-slate-500">{row.others}</td>
                    </tr>
                  ),
                )
              }
            </tbody>
          </table>
        </div>

        <div class="rounded-[2rem] bg-slate-900 p-8 text-white shadow-xl">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/20">
            <Target class="h-7 w-7 text-primary" />
          </div>
          <h3 class="mt-6 text-2xl font-semibold">
            {t("features.warmup.comparison.calloutTitle")}
          </h3>
          <p class="mt-4 text-base leading-relaxed text-slate-300">
            {t("features.warmup.comparison.calloutDescription")}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="rounded-[2rem] bg-slate-50 py-20">
    <div class="mx-auto max-w-6xl px-4">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
          {t("features.warmup.myths.title")}
        </h2>
        <p class="mt-4 text-lg text-slate-600 md:text-xl">
          {t("features.warmup.myths.subtitle")}
        </p>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {
          myths.map((myth: { title: string; description: string }) => (
            <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-rose-50">
                <X class="h-6 w-6 text-rose-500" />
              </div>
              <h3 class="mt-5 text-xl font-semibold text-slate-900">
                {myth.title}
              </h3>
              <p class="mt-3 text-base leading-relaxed text-slate-600">
                {myth.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="text-center">
    <div class="mx-auto max-w-4xl px-4">
      <div class="rounded-[2rem] border border-slate-200 bg-white px-6 py-10 shadow-sm md:px-10 md:py-12">
        <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">
          {t("features.warmup.bottomCta.title")}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
          {t("features.warmup.bottomCta.description")}
        </p>

        <div class="mt-8">
          <Button
            variant="primary"
            size="lg"
            href={buildSignupUrl({ context: "features_warmups_bottom" })}
          >
            {t("cta.buttonTrial")}
          </Button>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          {
            bottomHighlights.map((item: string) => (
              <div class="flex items-center gap-2 rounded-full bg-slate-100 px-4 py-2 text-sm font-medium text-slate-700">
                <Check class="h-4 w-4 text-emerald-500" />
                <span>{item}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</div>
