---
const { t } = Astro.props;
---

<div class="py-16 md:py-24">
  <div class="mx-auto max-w-3xl px-4">
    <!-- Hero Header -->
    <div class="mb-16 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
        {t("nav.privacy")}
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        {t("legal.privacy.title")}
      </h1>
      <p class="mt-4 text-lg text-slate-600">
        {t("legal.privacy.description")}
      </p>
    </div>

    <!-- Content -->
    <div class="prose prose-slate prose-lg max-w-none prose-headings:text-slate-900 prose-headings:font-bold prose-p:text-slate-600 prose-li:text-slate-600 prose-strong:text-slate-900">
      
      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.intro.title")}</h2>
        <p>{t("legal.privacy.intro.body1")}</p>
        <p>{t("legal.privacy.intro.body2")}</p>
        <p>{t("legal.privacy.intro.body3")}</p>
        
        <p class="font-semibold text-slate-900 mt-6 mb-4">{t("legal.privacy.intro.appliesTo.title")}</p>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.intro.appliesTo.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.intro.footer")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.collection.title")}</h2>
        <p>{t("legal.privacy.collection.intro")}</p>
        
        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.collection.personal.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.collection.personal.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.collection.usage.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.collection.usage.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.collection.usage.footer")}</p>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.collection.auto.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.collection.auto.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.collection.auto.footer")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.usage.title")}</h2>
        <p>{t("legal.privacy.usage.intro")}</p>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.usage.provide.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.usage.provide.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.usage.onboarding.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.usage.onboarding.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.usage.onboarding.footer")}</p>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.usage.support.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.usage.support.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.usage.performance.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.usage.performance.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.sharing.title")}</h2>
        <p>{t("legal.privacy.sharing.intro")}</p>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.sharing.providers.title")}</h3>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.sharing.providers.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.sharing.providers.footer")}</p>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.sharing.noSale.title")}</h3>
        <p>{t("legal.privacy.sharing.noSale.body")}</p>

        <h3 class="text-xl mt-8 mb-4">{t("legal.privacy.sharing.legal.title")}</h3>
        <p>{t("legal.privacy.sharing.legal.intro")}</p>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.sharing.legal.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.gdpr.basis.title")}</h2>
        <p>{t("legal.privacy.gdpr.basis.intro")}</p>
        <div class="space-y-6 mt-6">
          {t("legal.privacy.gdpr.basis.items").map((item: any) => (
            <div>
              <p class="font-bold text-slate-900 mb-1">{item.title}</p>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.gdpr.rights.title")}</h2>
        <p>{t("legal.privacy.gdpr.rights.intro")}</p>
        <div class="space-y-6 mt-6">
          {t("legal.privacy.gdpr.rights.items").map((item: any) => (
            <div>
              <p class="font-bold text-slate-900 mb-1">{item.title}</p>
              <p>{item.body}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.cookies.title")}</h2>
        <p>{t("legal.privacy.cookies.body1")}</p>
        <p class="font-semibold text-slate-900 mt-6 mb-4">{t("legal.privacy.cookies.listIntro")}</p>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.cookies.list").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.cookies.body2")}</p>
        <p>{t("legal.privacy.cookies.body3")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.retention.title")}</h2>
        <p>{t("legal.privacy.retention.body")}</p>
        <p class="font-semibold text-slate-900 mt-6 mb-4">{t("legal.privacy.retention.afterCancellation.title")}</p>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.retention.afterCancellation.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.retention.footer")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.security.title")}</h2>
        <p>{t("legal.privacy.security.intro")}</p>
        <ul class="list-disc pl-6 space-y-2 mb-6">
          {t("legal.privacy.security.items").map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
        <p>{t("legal.privacy.security.footer")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.children.title")}</h2>
        <p>{t("legal.privacy.children.body1")}</p>
        <p>{t("legal.privacy.children.body2")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.changes.title")}</h2>
        <p>{t("legal.privacy.changes.body1")}</p>
        <p>{t("legal.privacy.changes.body2")}</p>
        <p>{t("legal.privacy.changes.body3")}</p>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl mb-4">{t("legal.privacy.contact.title")}</h2>
        <p>{t("legal.privacy.contact.body")}</p>
        <div class="mt-6 p-6 rounded-2xl border border-slate-200 bg-slate-50">
          <p class="font-semibold text-slate-900">{t("legal.privacy.contact.email")}</p>
          <p class="text-slate-600">{t("legal.privacy.contact.company")}</p>
          <p class="text-slate-600 whitespace-pre-line">{t("legal.privacy.contact.address")}</p>
        </div>
      </section>

      <hr class="my-12 border-slate-200" />
      
      <div class="text-sm text-slate-500 italic">
        {t("legal.privacy.lastUpdated")}
      </div>
    </div>
  </div>
</div>
