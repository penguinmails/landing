---
const { t } = Astro.props;
---

<div class="py-16 md:py-24">
  <div class="mx-auto max-w-4xl px-4">
    <!-- Hero Header -->
    <div class="mb-16 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
        {t("contact.hero.tagline")}
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        {t("contact.hero.title")}
      </h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl mx-auto">
        {t("contact.hero.subtitle")}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Contact Info Cards -->
      <div class="space-y-6">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">{t("contact.info.title")}</h2>
        
        <!-- Email -->
        <div class="flex gap-4 p-6 rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">{t("contact.info.email.label")}</h3>
            <a href={`mailto:${t("contact.info.email.value")}`} class="text-lg font-bold text-slate-900 hover:text-primary transition-colors">
              {t("contact.info.email.value")}
            </a>
          </div>
        </div>

        <!-- Address -->
        <div class="flex gap-4 p-6 rounded-2xl bg-white border border-slate-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">{t("contact.info.address.label")}</h3>
            <p class="text-lg font-bold text-slate-900 whitespace-pre-line">
              {t("contact.info.address.value")}
            </p>
          </div>
        </div>

        <!-- Company -->
        <div class="flex gap-4 p-6 rounded-2xl bg-white border border-slate-200 shadow-sm">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-slate-500">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-1">{t("contact.info.company.label")}</h3>
            <p class="text-lg font-semibold text-slate-900">
              {t("contact.info.company.value")}
            </p>
          </div>
        </div>
      </div>

      <!-- Support Callout / Image -->
      <div class="bg-primary/5 rounded-3xl p-8 border border-primary/10 flex flex-col justify-center h-full">
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Fast Support</h3>
        <p class="text-lg text-slate-600 mb-8">
          We usually respond within 24 hours. Our support team is available Monday to Friday to help with any technical or billing questions you might have.
        </p>
        <div class="mt-auto">
            <div class="flex -space-x-2 mb-4">
                <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-200 flex items-center justify-center font-bold text-xs">P</div>
                <div class="w-10 h-10 rounded-full border-2 border-white bg-primary/20 flex items-center justify-center font-bold text-xs">M</div>
            </div>
            <p class="text-sm font-medium text-slate-500">Join 100+ agencies sending with us.</p>
        </div>
      </div>
    </div>
  </div>
</div>
