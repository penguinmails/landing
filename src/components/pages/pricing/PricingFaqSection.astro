---
import ArticleCard from "@/components/shared/ArticleCard.astro";
import { pricingFaqs } from "./data";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import type { TranslationKey } from "@/i18n/types";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="bg-zinc-50 py-20 md:py-24" id="faq">
  <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center text-4xl font-semibold tracking-tight text-zinc-900 md:text-5xl">
      {t("pricing.faq.title")}
    </h2>

    <div class="mt-10 space-y-5 md:mt-12">
      {
        pricingFaqs.map((item) => (
          <ArticleCard
            title={t(item.questionKey as TranslationKey)}
            description={t(item.answerKey as TranslationKey)}
          />
        ))
      }
    </div>
  </div>
</section>
