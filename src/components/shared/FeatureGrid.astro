---
import { cn } from "@/lib/utils";
interface Props {
  title: string;
  description: string;
  theme?: "light" | "dark";
  items?: {
    icon?: any;
    iconClass?: string;
    title: string;
    description: string;
  }[];
}
const { title, description, theme = "light", items = [] }: Props = Astro.props;
const isDark = theme === "dark";
const sectionBgClass = isDark ? "bg-stone-900" : "bg-slate-50";
const textClass = isDark ? "text-white" : "text-slate-900";
const descClass = isDark ? "text-gray-400" : "text-slate-600";
const cardBgClass = isDark
  ? "bg-stone-800 border-stone-700 hover:bg-stone-700"
  : "bg-white border-slate-200 shadow-[0_10px_30px_rgba(15,23,42,0.06)] hover:shadow-[0_14px_36px_rgba(15,23,42,0.08)]";
const cardTitleClass = isDark ? "text-white" : "text-slate-900";
const cardDescClass = isDark ? "text-gray-400" : "text-slate-600";
const iconWrapClass = isDark
  ? "flex h-14 w-14 items-center justify-center rounded-2xl bg-stone-700/80 text-white"
  : "flex h-20 w-20 items-center justify-center rounded-3xl bg-[#dbe8ff] text-primary";
---

<div
  class={cn(
    "rounded-3xl px-5 sm:px-12 py-16 sm:py-24 mx-auto shadow-xl",
    sectionBgClass,
  )}
>
  <div class="text-center mb-16 sm:mb-20 max-w-2xl mx-auto">
    <h2
      class={cn(
        "text-3xl font-bold tracking-tight sm:text-5xl leading-tight mb-6",
        textClass,
      )}
    >
      {title}
    </h2>
    <p class={cn("text-lg sm:text-xl leading-relaxed", descClass)}>
      {description}
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 sm:gap-6">
    {
      items.map((item) => (
        <div
          class={cn(
            "rounded-3xl p-8 sm:p-10 border flex flex-col gap-8 sm:gap-10 transition-all",
            cardBgClass,
          )}
        >
          <div class={iconWrapClass}>
            {item.icon && <item.icon class={item.iconClass} />}
          </div>
          <div>
            <h3
              class={cn(
                "font-semibold text-xl sm:text-[2rem] leading-snug mb-3 sm:mb-4 tracking-tight",
                cardTitleClass,
              )}
            >
              {item.title}
            </h3>
            <p
              class={cn(
                "text-base sm:text-[1.1rem] leading-relaxed",
                cardDescClass,
              )}
            >
              {item.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>
  <slot />
</div>
