---
import { languages } from "@/i18n/ui";
import { getLangFromUrl, useTranslatedPath } from "@/i18n/utils";
import { Languages } from "@lucide/astro";

const lang = getLangFromUrl(Astro.url);
// Get the current path without the language prefix for the switcher
const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const currentPathWithoutLang =
  segments[0] in languages ? `/${segments.slice(1).join("/")}` : pathname;
---

<div class="relative group">
  <button
    class="flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors"
    aria-label="Select Language"
  >
    <Languages class="w-4 h-4" />
    <span class="uppercase font-semibold">{lang}</span>
  </button>

  <div
    class="absolute right-0 top-full mt-1 hidden group-hover:block min-w-[120px] bg-white border border-gray-100 rounded-lg shadow-lg z-50 overflow-hidden"
  >
    {
      Object.entries(languages).map(([l, label]) => (
        <a
          href={useTranslatedPath(l as any)(currentPathWithoutLang)}
          class={`block px-4 py-2 text-sm transition-colors hover:bg-gray-50 ${
            l === lang
              ? "text-primary font-semibold bg-primary/5"
              : "text-gray-600"
          }`}
        >
          {label}
        </a>
      ))
    }
  </div>
</div>
