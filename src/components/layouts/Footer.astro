---
import FacebookIcon from "@/assets/icons/facebook.svg";
import InstagramIcon from "@/assets/icons/instagram.svg";
import Logo from "@/components/layouts/Logo.astro";
import { Image } from "astro:assets";
import { usecasesLinks, featuresLinks, companyLinks, legalLinks } from "@/lib/navigation";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer>
  <div class="mx-auto px-6 py-14 sm:px-8 lg:px-12 lg:py-16">
    <div class="flex flex-col items-start justify-between gap-12 lg:flex-row">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-6 leading-[1.35] text-zinc-600">
          {t("footer.description")}
        </p>

        <div class="mt-8 flex items-center gap-4">
          <a
            href="https://www.facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t("footer.social.facebook")}
            class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#d8e5f8] text-primary transition-colors hover:bg-[#c8dcf7]"
          >
            <Image src={FacebookIcon} alt={t("footer.social.facebook")} class="h-6 w-6" />
          </a>
          <a
            href="https://www.instagram.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t("footer.social.instagram")}
            class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#d8e5f8] text-primary transition-colors hover:bg-[#c8dcf7]"
          >
            <Image src={InstagramIcon} alt={t("footer.social.instagram")} class="h-6 w-6" />
          </a>
        </div>
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-4 justify-between md:w-full sm:grid-cols-3 flex-1 lg:max-w-3xl gap-10"
      >
        <div>
          <h3 class="font-bold text-zinc-900">{t("footer.sections.company")}</h3>
          <ul class="mt-5 space-y-3">
            {
              companyLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {t(link.labelKey) as string}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="font-bold text-zinc-900">{t("footer.sections.features")}</h3>
          <ul class="mt-5 space-y-3">
            {
              featuresLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {t(link.labelKey) as string}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="font-bold text-zinc-900">{t("footer.sections.usecases")}</h3>
          <ul class="mt-5 space-y-3">
            {
              usecasesLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {t(link.labelKey) as string}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-zinc-900">{t("footer.sections.legal")}</h3>
          <ul class="mt-5 space-y-3">
            {
              legalLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {t(link.labelKey) as string}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-primary px-6 py-3 text-center sm:px-8">
    <p class="text-sm font-bold text-[#f2b632] sm:text-base">
      &copy; {new Date().getFullYear()} {t("footer.copyright")}
    </p>
  </div>
</footer>
