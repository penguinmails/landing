---
import FacebookIcon from "@/assets/icons/facebook.svg";
import InstagramIcon from "@/assets/icons/instagram.svg";
import Logo from "@/components/layouts/Logo.astro";
import { Image } from "astro:assets";
const usecasesLinks = [
  { label: "Agencies", href: "/usecases#agencies" },
  { label: "Freelancers", href: "/usecases#freelancers" },
  { label: "Outbound Teams", href: "/usecases#outbound-teams" },
  { label: "Startups", href: "/usecases#startups" },
];

const resourcesLinks = [
  { label: "Blog", href: "/features#blog" },
  { label: "Tools", href: "/features#tools" },
];

const companyLinks = [
  { label: "About", href: "/features#about" },
  { label: "Contact", href: "/features#contact" },
];

const legalLinks = [
  { label: "Anti-Spam Policy", href: "/pricing#anti-spam-policy" },
  { label: "Privacy", href: "/pricing#privacy" },
  { label: "Refund Policy", href: "/pricing#refund-policy" },
  { label: "Terms", href: "/pricing#terms" },
];
---

<footer>
  <div class="mx-auto px-6 py-14 sm:px-8 lg:px-12 lg:py-16">
    <div class="flex flex-col items-start justify-between gap-12 lg:flex-row">
      <div class="max-w-sm">
        <Logo />
        <p class="mt-6 leading-[1.35] text-zinc-600">
          PenguinMails is an affordable cold email automation tool made for
          startups and agencies.
        </p>

        <div class="mt-8 flex items-center gap-4">
          <a
            href="https://www.facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#d8e5f8] text-primary transition-colors hover:bg-[#c8dcf7]"
          >
            <Image src={FacebookIcon} alt="Facebook" class="h-6 w-6" />
          </a>
          <a
            href="https://www.facebook.com"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[#d8e5f8] text-primary transition-colors hover:bg-[#c8dcf7]"
          >
            <Image src={InstagramIcon} alt="Instagram" class="h-6 w-6" />
          </a>
        </div>
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-4 justify-between md:w-full sm:grid-cols-3 lg:grid-rows-2 flex-1 lg:max-w-3xl gap-10"
      >
        <div>
          <h3 class="font-bold text-zinc-900">Usecases</h3>
          <ul class="mt-5 space-y-3">
            {
              usecasesLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="font-bold text-zinc-900">Resources</h3>
          <ul class="mt-5 space-y-3">
            {
              resourcesLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-zinc-900">Company</h3>
          <ul class="mt-5 space-y-3">
            {
              companyLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="lg:col-start-3">
          <h3 class="font-bold text-zinc-900">Legal</h3>
          <ul class="mt-5 space-y-3">
            {
              legalLinks.map((link) => (
                <li>
                  <a
                    class=" text-zinc-600 transition-colors hover:text-zinc-900 whitespace-nowrap"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-primary px-6 py-3 text-center sm:px-8">
    <p class="text-sm font-bold text-[#f2b632] sm:text-base">
      © 2021 — Copyright All Rights reserved
    </p>
  </div>
</footer>
