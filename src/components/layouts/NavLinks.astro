---
import Logo from "@/components/layouts/Logo.astro";
import ActiveIcon from "@/assets/icons/active-link-yellow-point.svg";
import ThreeLinesVerticalIcon from "@/assets/icons/menu-three-lines.svg";
/**
 * Close icon fallback: we reuse the existing menu icon and rotate it 90°
 * so we don't introduce a new asset dependency.
 */
import { cn } from "@/lib/utils";
import { Button } from "../ui/button";
const navLinks = [
  { name: "Home", href: "/" },
  {
    name: "Features",
    href: "/features",
  },
  {
    name: "Pricing",
    href: "/pricing",
  },
  {
    name: "Usecases",
    href: "/usecases",
  },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  return currentPath === href;
};
---

<nav class="hidden justify-self-center gap-7 md:flex">
  {
    navLinks.map((link) => {
      const active = isActive(link.href);

      return (
        <div class="flex flex-col items-center leading-none">
          <a
            href={link.href}
            class={cn(
              "text-sm font-medium text-gray-600 transition-colors hover:text-gray-900",
              { "font-semibold text-gray-900": active },
            )}
            data-active={active ? "true" : "false"}
          >
            {link.name}
          </a>
          {active && (
            <ActiveIcon
              class="mt-1 h-2 w-2 text-[#f2b632]"
              aria-hidden="true"
            />
          )}
        </div>
      );
    })
  }
</nav>

<div class="relative justify-self-end md:hidden">
  <Button
    id="mobile-nav-trigger"
    variant="ghost"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="mobile-nav-drawer"
  >
    <ThreeLinesVerticalIcon class="h-6 w-6 text-gray-600" aria-hidden="true" />
    <span class="sr-only">Open menu</span>
  </Button>





  <!-- Backdrop -->
  <div
    id="mobile-nav-backdrop"
    class="fixed inset-0 z-40 hidden bg-black/40"
    aria-hidden="true"
  ></div>

  <!-- Full-screen drawer -->
  <aside
    id="mobile-nav-drawer"
    class="fixed right-0 top-0 z-50 hidden h-dvh w-full bg-white shadow-xl"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-nav-title"
  >
    <div class="flex h-20 items-center justify-between px-5 md:px-8 border-b border-gray-100">
      <Logo />
      <Button id="mobile-nav-close" variant="ghost" className="px-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-gray-900"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        <span class="sr-only">Close menu</span>
      </Button>
    </div>

    <nav class="px-5 md:px-8 pb-8 pt-6">
      <div class="flex flex-col gap-6">
        {
          navLinks.map((link) => {
            const active = isActive(link.href);

            return (
              <a
                href={link.href}
                class={cn(
                  "text-[1.1rem] font-medium text-gray-900 transition-colors hover:text-gray-600",
                  { "font-semibold": active },
                )}
                data-active={active ? "true" : "false"}
              >
                {link.name}
              </a>
            );
          })
        }
      </div>
    </nav>
  </aside>

  <script is:inline>
    (() => {
      const trigger = document.getElementById("mobile-nav-trigger");
      const closeBtn = document.getElementById("mobile-nav-close");
      const drawer = document.getElementById("mobile-nav-drawer");
      const backdrop = document.getElementById("mobile-nav-backdrop");

      if (!trigger || !drawer || !backdrop || !closeBtn) return;

      const open = () => {
        drawer.classList.remove("hidden");
        backdrop.classList.remove("hidden");
        trigger.setAttribute("aria-expanded", "true");
        document.documentElement.style.overflow = "hidden";
      };

      const close = () => {
        drawer.classList.add("hidden");
        backdrop.classList.add("hidden");
        trigger.setAttribute("aria-expanded", "false");
        document.documentElement.style.overflow = "";
      };

      trigger.addEventListener("click", (e) => {
        e.preventDefault();
        open();
      });

      closeBtn.addEventListener("click", (e) => {
        e.preventDefault();
        close();
      });

      backdrop.addEventListener("click", () => close());

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") close();
      });

      drawer.addEventListener("click", (e) => {
        const target = e.target;
        if (target instanceof HTMLAnchorElement) close();
      });
    })();
  </script>
</div>
