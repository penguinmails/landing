---
import Logo from "@/components/layouts/Logo.astro";
import ActiveIcon from "@/assets/icons/active-link-yellow-point.svg";
import ThreeLinesVerticalIcon from "@/assets/icons/menu-three-lines.svg";
/**
 * Close icon fallback: we reuse the existing menu icon and rotate it 90°
 * so we don't introduce a new asset dependency.
 */
import { cn } from "@/lib/utils";
const navLinks = [
  { name: "Home", href: "/" },
  {
    name: "Features",
    href: "/features",
  },
  {
    name: "Pricing",
    href: "/pricing",
  },
  {
    name: "Usecases",
    href: "/usecases",
  },
];
const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  return currentPath === href;
};
---

<nav class="hidden justify-self-center gap-7 md:flex">
  {
    navLinks.map((link) => {
      const active = isActive(link.href);

      return (
        <div class="flex flex-col items-center leading-none">
          <a
            href={link.href}
            class={cn(
              "text-sm font-medium text-gray-600 transition-colors hover:text-gray-900",
              { "font-semibold text-gray-900": active },
            )}
            data-active={active ? "true" : "false"}
          >
            {link.name}
          </a>
          {active && (
            <ActiveIcon
              class="mt-1 h-2 w-2 text-[#f2b632]"
              aria-hidden="true"
            />
          )}
        </div>
      );
    })
  }
</nav>
