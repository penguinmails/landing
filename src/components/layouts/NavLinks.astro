---
import ActiveIcon from "@/assets/icons/active-link-yellow-point.svg";
/**
 * Close icon fallback: we reuse the existing menu icon and rotate it 90°
 * so we don't introduce a new asset dependency.
 */
import { cn } from "@/lib/utils";
import { Menu, X } from "@lucide/astro";
import Button from "../ui/Button.astro";
import Dropdown from "../ui/Dropdown.astro";
import Logo from "./Logo.astro";
import LoginButton from "./LoginButton.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils";
import { featuresLinks, usecasesLinks } from "@/lib/navigation";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Translate navigation links
// Translate navigation links
const translatedFeaturesLinks = featuresLinks.map(link => ({
  ...link,
  label: t(link.labelKey) as string,
  href: translatePath(link.href)
}));

const translatedUsecasesLinks = usecasesLinks.map(link => ({
  ...link,
  label: t(link.labelKey) as string,
  href: translatePath(link.href)
}));

const navLinks = [
  { name: t("nav.home"), href: translatePath("/") },
  {
    name: t("nav.features"),
    href: translatePath("/features"),
    dropdown: translatedFeaturesLinks,
  },
  {
    name: t("nav.pricing"),
    href: translatePath("/pricing"),
  },
  {
    name: t("nav.usecases"),
    href: translatePath("/usecases"),
    dropdown: translatedUsecasesLinks,
  },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  return currentPath === href;
};
---

<nav class="hidden justify-self-center gap-7 md:flex">
  {
    navLinks.map((link) => {
      const active = isActive(link.href);

      if (link.dropdown) {
        return (
          <div class="flex flex-col items-center leading-none">
            <Dropdown
              label={link.name}
              items={link.dropdown}
              active={active}
            />
            {active && (
              <ActiveIcon
                class="mt-1 h-2 w-2 text-[#f2b632]"
                aria-hidden="true"
              />
            )}
          </div>
        );
      }

      return (
        <div class="flex flex-col items-center leading-none">
          <a
            href={link.href}
            class={cn(
              "text-sm font-medium text-gray-600 transition-colors hover:text-gray-900",
              { "font-semibold text-gray-900": active },
            )}
            data-active={active ? "true" : "false"}
          >
            {link.name}
          </a>
          {active && (
            <ActiveIcon
              class="mt-1 h-2 w-2 text-[#f2b632]"
              aria-hidden="true"
            />
          )}
        </div>
      );
    })
  }
</nav>
<Button
  variant="ghost"
  className="md:hidden justify-self-end"
  aria-menu-trigger="Open navigation menu"
>
  <Menu class="h-6 w-6" aria-label="Open navigation menu" />
</Button>
<div class="hidden" aria-label="Mobile navigation menu" aria-menu-open="false">
  <div class="fixed h-screen w-full bg-white inset-0 z-50">
    <div class="relative mx-auto py-6.5 px-5 container">
      <div class="flex justify-between items-center">
        <Logo />
        <Button
          variant="ghost"
          className="absolute top-4 right-4"
          aria-label="Close navigation menu"
        >
          <X class="h-6 w-6 rotate-90" aria-hidden="true" />
        </Button>
      </div>
      <div class="mt-10 flex flex-col gap-6">
        {
          navLinks.map((link) => {
            const active = isActive(link.href);
            
            if (link.dropdown) {
              return (
                <div class="flex flex-col gap-3">
                  <div class="flex items-center justify-between">
                    <a
                      href={link.href}
                      class={cn(
                        "text-lg font-medium text-gray-600 transition-colors hover:text-gray-900",
                        { "font-semibold text-gray-900": active },
                      )}
                      data-active={active ? "true" : "false"}
                    >
                      {link.name}
                    </a>
                  </div>
                  <div class="ml-4 flex flex-col gap-3">
                    {link.dropdown.map((item) => (
                      <a
                        href={item.href}
                        class="text-sm font-medium text-gray-500 transition-colors hover:text-gray-900"
                      >
                        {item.label}
                      </a>
                    ))}
                  </div>
                </div>
              );
            }

            return (
              <a
                href={link.href}
                class={cn(
                  "text-lg font-medium text-gray-600 transition-colors hover:text-gray-900",
                  { "font-semibold text-gray-900": active },
                )}
                data-active={active ? "true" : "false"}
              >
                {link.name}
              </a>
            );
          })
        }
      </div>
      <LoginButton variant="outline" className="w-full mt-6" />
    </div>
  </div>
</div>

<script>
  const menuButton = document.querySelector(
    'button[aria-menu-trigger="Open navigation menu"]',
  );
  const mobileMenu = document.querySelector(
    'div[aria-label="Mobile navigation menu"]',
  );
  const closeButton = mobileMenu?.querySelector(
    'button[aria-label="Close navigation menu"]',
  );
  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    mobileMenu?.setAttribute("aria-menu-open", "true");
  }
  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    mobileMenu?.setAttribute("aria-menu-open", "false");
  }
  menuButton?.addEventListener("click", openMenu);
  closeButton?.addEventListener("click", closeMenu);
</script>
