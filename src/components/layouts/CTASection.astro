---
import { buildSignupUrl, type UtmSource } from "@/lib/cta";
import { PUBLIC_BOOK_DEMO_EMAIL } from "astro:env/client";
import Button from "../ui/Button.astro";

interface Props {
  ctaContext?: UtmSource;
  bottomContext?: UtmSource;
  title?: string;
  subtitle?: string;
  ctaText?: string;
  demoText?: string;
}

const {
  ctaContext = "cta_bottom",
  bottomContext,
  title = "Ready to Send Emails That Actually Land?",
  subtitle = "Stop guessing. Start delivering.",
  ctaText = "Start Free Trial",
  demoText = "Book a Demo",
} = Astro.props;

const bookDemoEmailHref = `mailto:${PUBLIC_BOOK_DEMO_EMAIL}`;

const signupUrl = bottomContext
  ? buildSignupUrl({ context: bottomContext, plan: "growth" })
  : buildSignupUrl({ context: ctaContext, plan: "growth" });
---

<section
  class="w-full bg-linear-to-r from-[#1f5fe0] via-primary to-[#1374f5] py-16 sm:py-20"
  id="final-cta"
>
  <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
      <h2
        class="text-balance text-4xl font-semibold leading-tight text-white sm:text-5xl md:text-6xl"
      >
        {title}
      </h2>

      <p class="mt-4 text-xl text-white/95 sm:text-2xl">
        {subtitle}
      </p>

      <div
        class="mt-9 flex w-full max-w-xl flex-col items-center justify-center gap-4 sm:flex-row"
      >
        <Button
          href={signupUrl}
          className="cta-pulse cta-accent-light min-h-14 w-full rounded-full px-8 text-xl font-semibold text-primary sm:w-auto sm:min-w-56"
        >
          {ctaText}
        </Button>
        <Button
          href={bookDemoEmailHref}
          className="min-h-14 w-full rounded-full border border-white/70 bg-transparent px-8 text-xl font-semibold text-white hover:border-white hover:bg-white/10 sm:w-auto sm:min-w-56"
        >
          {demoText}
        </Button>
      </div>

      <p class="mt-6 text-sm text-white/90 sm:text-lg">
        No credit card required. 14-day free trial.
      </p>
    </div>
  </div>
</section>
