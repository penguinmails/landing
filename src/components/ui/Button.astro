---
import { cn } from "@/lib/utils";
import type { ClassNameValue } from "tailwind-merge";

interface Props {
  class?: ClassNameValue;
  className?: ClassNameValue;
  variant?: "primary" | "secondary" | "outline" | "ghost" | "link";
  size?: "sm" | "md" | "lg";
  href?: string;
  [x: string]: any;
}
const {
  class: classProp,
  className,
  variant = "primary",
  size = "md",
  href,
  ...props
} = Astro.props;
const classes = cn(className, classProp);
const baseStyles = cn(
  "inline-flex items-center justify-center rounded-md font-medium transition-[color,background-color,border-color,box-shadow,transform] duration-200 ease-out focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 motion-safe:hover:-translate-y-0.5",
);
const variantStyles = {
  primary: "bg-primary text-white hover:bg-primary-700 focus:ring-primary-500",
  secondary: "bg-secondary text-white hover:bg-yellow-500 focus:ring-secondary",
  outline:
    "border-[1.5px] border-primary text-primary hover:bg-gray-50 focus:ring-primary-500",
  ghost: "text-gray-700 hover:bg-gray-100 focus:ring-gray-500",
  link: "text-primary hover:underline focus:ring-primary-500",
};
const sizeStyles = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-4 py-2 text-base",
  lg: "px-8 py-4 text-lg",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  class={cn(baseStyles, variantStyles[variant], sizeStyles[size], classes)}
  {...props}
>
  <slot />
</Tag>
