---
import { cn } from '@/lib/utils';
import type { ClassNameValue } from 'tailwind-merge';


interface Props {
  className ?: ClassNameValue;
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'link';
  size?: 'sm' | 'md' | 'lg';
}
const { className, variant = 'primary', size = 'md' , ...props } = Astro.props;
const baseStyles = cn(
    "inline-flex items-center justify-center rounded-md font-medium transition-colors focus:oultine-none disabled:opacity-50 disabled:pointer-events-none",
    className
);
const variantStyles = {
    primary: "bg-primary-600 text-white hover:bg-primary-700 focus:ring-primary-500",
    secondary: "bg-gray-600 text-white hover:bg-gray-700 focus:ring-gray-500",
    outline: "border border-gray-300 text-gray-700 hover:bg-gray-100 focus:ring-gray-500",
    ghost: "text-gray-700 hover:bg-gray-100 focus:ring-gray-500",
    link: "text-primary-600 hover:underline focus:ring-primary-500",
    };
const sizeStyles = {
    sm: "px-3 py-1.5 text-sm",
    md: "px-4 py-2 text-base",
    lg: "px-6 py-3 text-lg"
};


---
<button class={cn(
    baseStyles,
    variantStyles[variant],
    sizeStyles[size]
)}
{...props}>
    <slot />
</button>