---
import { cn } from "@/lib/utils";

interface Props {
  value: string;
  className?: string;
}

const { value, className } = Astro.props;
---

<div
  role="tabpanel"
  data-value={value}
  tabindex="0"
  class={cn(
    "mt-2 ring-offset-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-950 focus-visible:ring-offset-2 hidden",
    className,
  )}
>
  <slot />
</div>
