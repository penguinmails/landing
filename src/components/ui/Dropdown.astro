---
import { ChevronDown } from "@lucide/astro";
import { cn } from "@/lib/utils";

export interface Props {
  label: string;
  items: { label: string; href: string }[];
  active?: boolean;
}

const { label, items, active = false } = Astro.props;
// Generate a unique ID for the dropdown
const id = Math.random().toString(36).substring(2, 9);
---

<div class="relative dropdown-container" id={`dropdown-${id}`}>
  <button
    class={cn(
      "flex items-center gap-1 text-sm font-medium text-gray-600 transition-colors hover:text-gray-900 dropdown-trigger",
      { "font-semibold text-gray-900": active }
    )}
    aria-haspopup="true"
    aria-expanded={active ? "true" : "false"}
    aria-controls={`menu-${id}`}
  >
    {label}
    <ChevronDown class="h-4 w-4 transition-transform dropdown-icon" />
  </button>
  
  <div 
    id={`menu-${id}`}
    class="absolute left-0 top-full mt-2 min-w-48 rounded-lg bg-white py-2 shadow-lg dropdown-menu transition-all duration-200 z-50 invisible opacity-0 translate-y-[-10px]"
  >
    {items.map((item) => (
      <a
        href={item.href}
        class="block px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors"
      >
        {item.label}
      </a>
    ))}
  </div>
</div>

<style>
  .dropdown-container.open .dropdown-menu {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
  }
  .dropdown-container.open .dropdown-icon {
    transform: rotate(180deg);
  }
</style>

<script>
  function setupDropdowns() {
    const dropdowns = document.querySelectorAll('.dropdown-container');
    
    dropdowns.forEach(dropdown => {
      const trigger = dropdown.querySelector('.dropdown-trigger');
      const menu = dropdown.querySelector('.dropdown-menu');
      
      if (!trigger || !menu) return;
      
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const isOpen = dropdown.classList.contains('open');
        
        // Close all other dropdowns
        document.querySelectorAll('.dropdown-container').forEach(d => {
          d.classList.remove('open');
          d.querySelector('.dropdown-trigger')?.setAttribute('aria-expanded', 'false');
        });
        
        if (!isOpen) {
          dropdown.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target || !(e.target instanceof Element)) return;
      if (!e.target.closest('.dropdown-container')) {
        document.querySelectorAll('.dropdown-container.open').forEach(d => {
          d.classList.remove('open');
          d.querySelector('.dropdown-trigger')?.setAttribute('aria-expanded', 'false');
        });
      }
    });

    // Handle escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.dropdown-container.open').forEach(d => {
          d.classList.remove('open');
          const trigger = d.querySelector('.dropdown-trigger');
          trigger?.setAttribute('aria-expanded', 'false');
          if (trigger instanceof HTMLElement) trigger.focus();
        });
      }
    });
  }

  // Setup on initial load
  setupDropdowns();
  
  // Re-setup if using View Transitions
  document.addEventListener('astro:page-load', setupDropdowns);
</script>
