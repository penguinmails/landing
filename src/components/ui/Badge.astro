---
import { cn } from "@/lib/utils";
import type { ClassNameValue } from "tailwind-merge";
import type { BadgeVariant } from "./types";
interface Props {
  variant?: BadgeVariant;
  className?: ClassNameValue;
}
const { variant = "primary", className } = Astro.props;
const variantClasses = {
  primary: "bg-blue-600 text-white",
  secondary: "bg-gray-600 text-white",
  success: "bg-green-600 text-white",
  error: "bg-red-600 text-white",
  warning: "bg-yellow-500 text-white",
};
const baseClasses: ClassNameValue =
  "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium whitespace-nowrap";
---

<span class={cn(baseClasses, variantClasses[variant], className)}>
  <slot />
</span>
