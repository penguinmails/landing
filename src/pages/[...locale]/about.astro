---
import AboutPage from "@/components/pages/company/AboutPage.astro";
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { ui } from "@/i18n/ui";

const { locale } = Astro.params;

if (locale && !(locale in ui)) {
  return Astro.redirect("/404");
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const ctaOverride = {
  context: "about_page_bottom" as const,
  title: t("about.inlineCta.title"),
  subtitle: t("about.inlineCta.subtitle"),
  ctaText: t("about.inlineCta.button"),
};
---

<Layout
  title={`${t("about.title")} | ${t("site.title")}`}
  description={t("about.description")}
  ctaOverride={ctaOverride}
>
  <main class="bg-white">
    <AboutPage t={t} />
  </main>
</Layout>
