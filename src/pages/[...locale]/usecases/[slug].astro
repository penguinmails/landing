---
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils";
import { getUsecaseBySlug } from "@/lib/usecases-data";
import UsecaseLayout from "@/components/pages/usecases/UsecaseLayout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(translatePath("/usecases"), 302);
}

const usecase = getUsecaseBySlug(slug);

if (!usecase) {
  return Astro.rewrite(translatePath("/404"));
}
---

<Layout 
  title={`${t(usecase.titleKey)} | ${t("site.title")}`}
  description={t(usecase.descriptionKey) as string}
>
  <UsecaseLayout usecaseSlug={slug} t={t} lang={lang} />
</Layout>
