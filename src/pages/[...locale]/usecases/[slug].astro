---
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { showDefaultLang, defaultLang } from "@/i18n/ui";
import { getUsecaseBySlug } from "@/lib/usecases-data";
import UsecaseLayout from "@/components/pages/usecases/UsecaseLayout.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { slug } = Astro.params;

// Helper function to generate localized paths - used to avoid code duplication
const createLocalizedPath = (basePath: string) => !showDefaultLang && lang === defaultLang ? basePath : `/${lang}${basePath}`;
// Ensure TypeScript sees the function as used
void createLocalizedPath;

if (!slug) {
  return Astro.redirect(createLocalizedPath("/usecases"), 302);
}

const usecase = getUsecaseBySlug(slug);

if (!usecase) {
  return Astro.rewrite(createLocalizedPath("/404"));
}
---

<Layout 
  title={`${t(usecase.titleKey)} | ${t("site.title")}`}
  description={t(usecase.descriptionKey) as string}
>
  <UsecaseLayout usecaseSlug={slug} t={t as (key: string) => any} lang={lang} />
</Layout>
