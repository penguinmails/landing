---
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { showDefaultLang, defaultLang } from "@/i18n/ui";
import { getUsecaseBySlug } from "@/lib/usecases-data";
import UsecaseLayout from "@/components/pages/usecases/UsecaseLayout.astro";

// Ensure imported bindings are marked as used (they are referenced in redirect logic)
void showDefaultLang;
void defaultLang;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(!showDefaultLang && lang === defaultLang ? "/usecases" : `/${lang}/usecases`, 302);
}

const usecase = getUsecaseBySlug(slug);

if (!usecase) {
  return Astro.rewrite(!showDefaultLang && lang === defaultLang ? "/404" : `/${lang}/404`);
}
---

<Layout 
  title={`${t(usecase.titleKey)} | ${t("site.title")}`}
  description={t(usecase.descriptionKey) as string}
>
  <UsecaseLayout usecaseSlug={slug} t={t} lang={lang} />
</Layout>
