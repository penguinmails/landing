---
import UsecaseLayout from "@/components/pages/usecases/UsecaseLayout.astro";
import { defaultLang, showDefaultLang } from "@/i18n/ui";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";
import { getUsecaseBySlug } from "@/lib/usecases-data";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(
    !showDefaultLang && lang === defaultLang
      ? "/usecases"
      : `/${lang}/usecases`,
    302,
  );
}

const usecase = getUsecaseBySlug(slug);

if (!usecase) {
  return Astro.rewrite(
    !showDefaultLang && lang === defaultLang ? "/404" : `/${lang}/404`,
  );
}
---

<Layout
  title={`${t(usecase.titleKey)} | ${t("site.title")}`}
  description={t(usecase.descriptionKey) as string}
>
  <UsecaseLayout
    usecaseSlug={slug as
      | "agencies"
      | "freelancers"
      | "outbound-teams"
      | "startups"}
    t={t}
    lang={lang}
  />
</Layout>
