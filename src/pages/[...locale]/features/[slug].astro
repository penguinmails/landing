---
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations, useTranslatedPath } from "@/i18n/utils";
import { getFeatureBySlug } from "@/lib/features-data";
import { featuresLinks } from "@/lib/navigation";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect(translatePath("/features"), 302);
}

const feature = getFeatureBySlug(slug);

if (!feature) {
  return Astro.rewrite(translatePath("/404"));
}

if (slug !== feature.slug) {
  return Astro.redirect(translatePath(`/features/${feature.slug}`), 301);
}

const FeatureComponent = feature.component;
const Icon = feature.icon;

const ctaOverride = feature.cta
  ? {
      context: feature.cta.context,
      title: t(feature.cta.titleKey) as string,
      subtitle: t(feature.cta.subtitleKey) as string,
    }
  : undefined;
---

<Layout
  title={`${t(feature.titleKey)} | ${t("site.title")}`}
  description={t(feature.descriptionKey) as string}
  ctaOverride={ctaOverride}
>
  {FeatureComponent ? (
    <!-- Render full detailed feature component if available -->
    <FeatureComponent t={t} />
  ) : (
    <!-- Fallback to minimal view for features without full components -->
    <div class="container mx-auto px-5 py-20 md:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="flex items-center gap-4 mb-8">
          <div class="p-4 rounded-xl bg-blue-50">
            <Icon class={feature.iconClass} />
          </div>
          <h1 class="text-4xl font-bold text-gray-900">
            {t(feature.titleKey)}
          </h1>
        </div>
        
        <p class="text-xl text-gray-600 mb-12">
          {t(feature.descriptionKey)}
        </p>

        <div class="border-t border-gray-200 pt-12">
          <h2 class="text-xl font-semibold text-gray-900 mb-6">{t("features.otherFeatures")}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {featuresLinks.map(link => (
              <a
                href={translatePath(link.href)}
                class="p-4 rounded-lg border border-gray-200 hover:border-primary hover:bg-blue-50 transition-all"
              >
                {t(link.labelKey)}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}
</Layout>
