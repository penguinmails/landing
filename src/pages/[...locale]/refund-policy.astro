---
import RefundPolicyPage from "@/components/pages/legal/RefundPolicyPage.astro";
import Layout from "@/layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { ui } from "@/i18n/ui";

const { locale } = Astro.params;

if (locale && !(locale in ui)) {
  return Astro.redirect("/404");
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t("legal.refund.title")} | ${t("site.title")}`} description={t("legal.refund.description")}>
  <main class="bg-white">
    <RefundPolicyPage t={t} />
  </main>
</Layout>
